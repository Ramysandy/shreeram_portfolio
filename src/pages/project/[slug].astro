---
import '../../styles/global.css';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return ['3ducate', 'siteiq', 'pinpoint', 'piggilytics', 'dealscout', 'covpred', 'visionsentinel', 'veridion-x'].map(slug => ({ params: { slug } }));
}

function getProjectData(slug: string) {
  const d: Record<string, any> = {
    '3ducate': {
      title: '3Ducate', headline: 'AR Anatomical Platform with Generative AI Contextual Explanations',
      award: '1st Place — HawkHack 2025', date: 'January 2025', duration: '24 hours', team: '4 members',
      tags: ['Python', 'AR', 'Computer Vision', 'Generative AI'], category: 'EDTECH & AR',
      images: ['/images/projects/3ducate-1.jpeg','/images/projects/3ducate-2.jpeg','/images/projects/3ducate-3.jpeg','/images/projects/3ducate-4.jpeg'],
      overview: '3Ducate layers augmented reality over anatomical models with AI explanations on demand. Built in 24 hours at HawkHack 2025 and awarded first place.',
      problem: 'Medical education relies on textbooks and 2D diagrams. Students struggle to understand 3D anatomy without expensive physical models or cadaver lab access. Existing digital solutions are static and non-interactive.',
      solution: 'An AR system that detects surfaces in real-time and overlays detailed anatomical models. Students tap any structure to receive a Gemini-powered natural language explanation instantly.',
      features: [
        { title: 'Real-time Surface Detection', desc: 'Uses ARKit/ARCore to anchor models precisely onto physical surfaces.' },
        { title: 'AI-Powered Explanations', desc: 'Gemini API generates contextual explanations for any selected anatomical structure on demand.' },
        { title: 'Multi-Model Library', desc: 'Complete library from skeletal to muscular and vascular systems.' },
        { title: 'Offline Mode', desc: 'Core AR functionality works without internet; AI explanations queue for later delivery.' },
      ],
      techStack: { 'Frontend': ['React Native', 'ARKit', 'ARCore'], 'AI / ML': ['Google Gemini API', 'OpenCV'], 'Backend': ['Python', 'FastAPI'], 'Infrastructure': ['GCP Cloud Run', 'Firebase'] },
    },
    'siteiq': {
      title: 'SiteIQ', headline: 'Autonomous AI Agent Delivering Invest/Avoid Verdicts on NYC Real Estate',
      award: '3rd Place — Anti-Slopathon, Mar 2026', date: 'March 2026', duration: '48 hours', team: '3 members',
      tags: ['Python', 'Geospatial APIs', 'Generative AI'], category: 'REAL ESTATE & AI',
      images: ['/images/projects/siteiq-1.jpg','/images/projects/siteiq-2.jpg','/images/projects/siteiq-3.jpg','/images/projects/siteiq-4.jpg'],
      overview: 'SiteIQ fuses geospatial mapping, live transit data, and Generative AI to produce structured investment reports — automating analysis from hours down to under 3 seconds.',
      problem: 'Real estate investors make high-stakes decisions on incomplete information. Analyzing transit access, zoning, demographics, and market comps takes days and requires multiple specialist tools.',
      solution: 'SiteIQ ingests live NYC transit feeds, zoning data, and property records into a unified geospatial pipeline. An autonomous reasoning agent issues a binary Invest/Avoid verdict with a structured supporting report.',
      features: [
        { title: 'Live Data Ingestion', desc: 'Real-time NYC transit APIs, zoning records, and property market feeds via GCP Pub/Sub.' },
        { title: 'Autonomous Reasoning Agent', desc: 'LLM-based agent with tool access for data querying, calculation, and report generation.' },
        { title: 'Structured Report Output', desc: 'Every verdict ships with a JSON report enabling full audit traceability.' },
        { title: 'React Dashboard', desc: 'Interactive map visualization with drill-down verdict details for each property.' },
      ],
      techStack: { 'AI / Agents': ['LLM Reasoning Agent', 'Google Gemini API', 'RAG'], 'Data': ['GCP Pub/Sub', 'BigQuery', 'Geospatial APIs'], 'Frontend': ['React', 'Mapbox GL'], 'Backend': ['Python', 'FastAPI'] },
    },
    'pinpoint': {
      title: 'Pin Point', headline: 'Decentralized Anti-Deepfake Protocol Anchoring Physical Reality on Solana',
      award: 'Best Use of Solana — QuackHacks, Feb 2026', date: 'February 2026', duration: '24 hours', team: '4 members',
      tags: ['On-device ML', 'Solana', 'Blockchain', 'Computer Vision'], category: 'WEB3 & SECURITY',
      images: ['/images/projects/pinpoint-1.jpg','/images/projects/pinpoint-2.jpg','/images/projects/pinpoint-3.jpg'],
      overview: 'Pin Point immutably stamps location-verified media on-chain with on-device ML filtering, creating an unforgeable audit trail against deepfake proliferation. Shipped end-to-end in 24 hours.',
      problem: 'Deepfake technology enables fabrication of video and audio evidence, eroding trust in digital media. Centralized verification authorities are single points of failure.',
      solution: 'Pin Point runs ML filtering on-device before capturing, stamps each piece of media with GPS data, and anchors the hash to the Solana blockchain for trustless, immutable verification.',
      features: [
        { title: 'On-Device ML Authenticity Filter', desc: 'Detects manipulation artifacts before capture, preventing tampered media from entering the pipeline.' },
        { title: 'GPS Cryptographic Anchoring', desc: 'Media is bound to precise GPS coordinates and timestamp before Solana submission.' },
        { title: 'Immutable On-Chain Record', desc: 'Solana ledger stores the evidence hash with no central authority required.' },
        { title: 'Instant Public Verification', desc: 'Any viewer can verify authenticity in real-time via the public Solana explorer.' },
      ],
      techStack: { 'Blockchain': ['Solana', 'Anchor Framework', 'Web3.js'], 'AI / ML': ['TensorFlow Lite', 'On-device CV'], 'Mobile': ['React Native', 'Expo'], 'Backend': ['Python', 'FastAPI'] },
    },
    'piggilytics': {
      title: 'Piggilytics AI', headline: 'AI Financial Platform Generating Video Explainers of Your Spending Behavior',
      award: null, date: 'November 2024', duration: '3 weeks', team: 'Solo',
      tags: ['Python', 'Flask', 'PyTorch', 'Gemini API'], category: 'FINTECH',
      images: ['/images/projects/piggilytics-1.jpg','/images/projects/piggilytics-2.jpg','/images/projects/piggilytics-3.jpg','/images/projects/piggilytics-4.jpg'],
      overview: 'Piggilytics automates bank statement parsing, builds live dashboards, and produces AI-narrated video breakdowns of personal finance patterns for non-technical users.',
      problem: 'Personal finance apps display data but do not explain it. Most users cannot interpret spending trends without financial literacy. Video explanation is most accessible but requires expensive human advisors.',
      solution: 'Piggilytics parses uploaded bank statements via NLP, categorizes transactions automatically, builds live chart dashboards, and uses the Gemini API to generate an AI-voiced video breakdown personalized to each user.',
      features: [
        { title: 'Automatic Statement Parsing', desc: 'NLP models extract transactions from PDF bank statements across all major formats.' },
        { title: 'Smart Categorization', desc: 'PyTorch classifier labels every transaction with 94% accuracy across 18 spending categories.' },
        { title: 'Live Dashboard', desc: 'Flask + Chart.js dashboard with real-time filtering and trend visualization.' },
        { title: 'AI Video Generator', desc: 'Gemini API scripts a personalized financial narrative delivered as a watchable video.' },
      ],
      techStack: { 'AI / ML': ['PyTorch', 'Google Gemini API', 'NLP', 'TTS'], 'Backend': ['Python', 'Flask', 'PostgreSQL'], 'Frontend': ['Chart.js', 'HTML/CSS'], 'Infrastructure': ['Docker', 'GCP Cloud Run'] },
    },
    'dealscout': {
      title: 'Deal Scout', headline: 'Full-Stack Price Comparison App from Figma Wireframe to Azure Production in Two Weeks',
      award: null, date: 'August 2023', duration: '2 weeks', team: 'Solo',
      tags: ['React', 'Python', 'Azure', 'Web Scraping'], category: 'E-COMMERCE',
      images: ['/images/projects/dealscout-1.png','/images/projects/dealscout-2.png','/images/projects/dealscout-3.png','/images/projects/dealscout-4.png'],
      overview: 'Deal Scout aggregates prices across major e-commerce platforms and alerts users when prices drop. Built as a velocity experiment compressing 3-month timelines into 2 weeks.',
      problem: 'Consumers lose hundreds of dollars annually buying at non-optimal prices. Existing comparison tools are slow, outdated, and lack proactive alerts — requiring manual checking.',
      solution: 'Deal Scout runs distributed web-scraping pipelines on Azure Functions, normalizes product data, and surfaces the best current price with historical trend charts. Users subscribe to price drops and receive instant notifications.',
      features: [
        { title: 'Distributed Scraping Pipeline', desc: 'Parallel Azure Functions scrape 8+ major retailers on scheduled intervals.' },
        { title: 'Price Drop Alerts', desc: 'Email/push notifications triggered when watched products drop below user-set thresholds.' },
        { title: 'Historical Price Charts', desc: 'React charts visualize 90-day price history to identify seasonal patterns and optimal buy windows.' },
        { title: 'Product URL Import', desc: 'Paste any product URL and Deal Scout auto-detects the retailer and activates tracking.' },
      ],
      techStack: { 'Frontend': ['React', 'Recharts', 'Tailwind CSS'], 'Backend': ['Python', 'FastAPI', 'SQLAlchemy'], 'Infrastructure': ['Azure Functions', 'Azure SQL', 'Azure Blob'], 'Tooling': ['Playwright', 'Beautiful Soup', 'Redis'] },
    },
    'visionsentinel': {
      title: 'VisionSentinel AI', headline: 'AI Video Red Flag Analyzer Flagging Hazards and Criminal Activity in Real Time',
      award: null, date: 'April 2025', duration: '24 hours', team: '4 members',
      tags: ['Python', 'YOLOv8', 'Gemini API', 'Streamlit', 'OpenCV'], category: 'PUBLIC SAFETY & AI',
      images: ['/images/projects/visionsentinel-1.jpg','/images/projects/visionsentinel-2.jpg','/images/projects/visionsentinel-3.jpg'],
      overview: 'VisionSentinel AI gives first responders, safety officers, and journalists a fast AI-driven way to analyze raw video footage for hazards or criminal activity — surfacing what human eyes miss in chaotic scenes.',
      problem: 'In crowded or chaotic scenes, human analysts miss subtle but dangerous cues in video footage. Manual review is slow, costly, and error-prone — particularly under time pressure for field operators who need instant situational awareness.',
      solution: 'Video is processed frame-by-frame through YOLOv8 for object detection, then passed to Gemini 1.5 Pro which generates a structured incident report with timestamps, severity levels, and descriptions. Serper API fetches live safety tips based on detected flags — all without any paid API.',
      features: [
        { title: 'YOLOv8 Object Detection', desc: 'Real-time detection of people, vehicles, weapons, and key objects with bounding box annotation on every processed frame.' },
        { title: 'Gemini Scene Analysis', desc: 'Gemini 1.5 Pro generates structured incident reports with detailed descriptions, timestamps, and Low/Medium/High severity ratings.' },
        { title: 'Visual Timeline & Dashboard', desc: 'Dual-plot timeline and bar graph visualize precisely when and where high-risk events occur across the footage.' },
        { title: 'Safety Recommendation Engine', desc: 'Serper API fetches real-time prevention strategies and safety tips based on detected red flags.' },
      ],
      techStack: { 'AI / ML': ['Google Gemini 1.5 Pro', 'YOLOv8 (Ultralytics)', 'OpenCV'], 'Frontend': ['Streamlit', 'Matplotlib'], 'Backend': ['Python', 'dotenv'], 'APIs': ['Serper API', 'Base64/MIME'] },
    },
    'veridion-x': {
      title: 'VERIDION-X', headline: 'Bitcoin Lightning Bounty Marketplace Paying Investigators in Sats for Catching Corporate Greenwashing',
      award: null, date: 'April 2026', duration: '48 hours', team: 'Solo',
      tags: ['Bitcoin Lightning', 'React 19', 'Node.js', 'FROST', 'Groq'], category: 'WEB3 & BITCOIN',
      images: ['/images/projects/veridion-x-1.jpg','/images/projects/veridion-x-2.jpg','/images/projects/veridion-x-3.jpg'],
      overview: 'VERIDION-X is a gig economy for fraud detection — investigators earn Bitcoin for catching corporate ESG greenwashing. Oracle nodes reach cryptographic consensus via FROST signatures; verdicts are sealed on Bitcoin and published to Nostr. Submitted to MIT Bitcoin Hackathon.',
      problem: 'Most corporate ESG claims are never independently verified. Investors cannot distinguish genuine sustainability from marketing fiction. There is no economic incentive to find fraud and no global payment layer to compensate investigators without banks or KYC.',
      solution: 'Investigators claim bounties on posted companies. Three independent oracle nodes query live government data (EIA, EPA, SEC, NASA) and reach 2-of-3 FROST threshold consensus. Fraud detection triggers a real BOLT11 Lightning invoice — payment settles in under one second, globally, with no intermediary.',
      features: [
        { title: 'FROST 2-of-3 Oracle Consensus', desc: 'Three independent oracle nodes use Flexible Round-Optimised Schnorr Threshold signatures — no single node controls the verdict.' },
        { title: 'Live Government Data Audits', desc: 'Real-time queries against EIA renewable data, EPA emissions records, SEC EDGAR filings, and NASA POWER satellite imagery.' },
        { title: 'Sub-Second Bitcoin Lightning Payments', desc: 'LNbits generates real BOLT11 invoices; investigators scan with any Lightning wallet and receive payment in under one second.' },
        { title: 'Permanent Nostr Publication', desc: 'Verdicts are sealed via Bitcoin Taproot OP_RETURN on testnet and published to Nostr — permanently uncensorable and independently verifiable.' },
      ],
      techStack: { 'Blockchain': ['Bitcoin Lightning', 'LNbits', 'BOLT11', 'Taproot', 'Nostr'], 'Cryptography': ['FROST', 'Schnorr Signatures', 'Shamir Secret Sharing'], 'Frontend': ['React 19', 'Framer Motion', 'Recharts', 'Zustand'], 'Backend': ['Node.js ESM', 'Express', 'Groq 70B'] },
    },
    'covpred': {
      title: 'CovPred', headline: 'End-to-End Epidemiology & Genomics Analytics Platform Built as Year-Long Thesis',
      award: null, date: 'May 2024', duration: '12 months', team: 'Solo (Thesis)',
      tags: ['Python', 'CDC APIs', 'Gemini API', 'Bioinformatics'], category: 'RESEARCH',
      images: ['/images/projects/covpred-1.png','/images/projects/covpred-2.png','/images/projects/covpred-3.png','/images/projects/covpred-4.png','/images/projects/covpred-5.png'],
      overview: 'CovPred integrates public health, DNA mutation, and research datasets with AI-generated official reports and epidemic-spread dashboards.',
      problem: 'Epidemiology and genomics datasets exist in silos across CDC, NIH, and academic databases. Synthesis requires domain expertise, manual processing, and weeks of analysis.',
      solution: 'CovPred automatically ingests CDC feeds, government datasets, and genomic databases, correlates DNA mutation patterns with epidemic trajectory data, and auto-generates formatted public health reports via Gemini API.',
      features: [
        { title: 'Multi-Source Data Fusion', desc: 'Automated ETL across CDC, NIH, NCBI, and WHO datasets with normalization.' },
        { title: 'Genomic Mutation Tracker', desc: 'Visualizes variant emergence and spread velocity alongside geographic outbreak data.' },
        { title: 'Epidemic Spread Dashboard', desc: 'Interactive dashboard with time-series modeling and regional trend breakdowns.' },
        { title: 'AI Report Generator', desc: 'Gemini API generates formatted epidemiological reports from raw data — no manual writing required.' },
      ],
      techStack: { 'Data Science': ['Python', 'Pandas', 'NumPy', 'Scikit-learn'], 'Bioinformatics': ['Biopython', 'NCBI Entrez API', 'CDC WONDER API'], 'AI': ['Google Gemini API', 'NLP'], 'Visualization': ['Plotly', 'Dash', 'Matplotlib'] },
    },
  };
  return d[slug];
}

const { slug } = Astro.params;
const project = getProjectData(slug);
if (!project) return Astro.redirect('/');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={`${project.title} — ${project.overview}`} />
  <title>{project.title} — The Shreeram Chronicle</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Playfair+Display+SC:wght@400;700;900&family=IBM+Plex+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" />
</head>
<body class="bg-paper">

  <nav class="sticky top-0 z-50 bg-paper border-b-2 border-ink no-print">
    <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-9">
      <div class="flex items-center gap-4">
        <a href={`${base}projects`} class="font-mono text-caption uppercase tracking-widest text-ink hover:text-ink-light transition-colors">← All Projects</a>
        <span class="text-ink-faded hidden sm:block">·</span>
        <span class="font-mono text-caption text-ink-faded hidden sm:block">{project.category}</span>
      </div>
      <a href={base} class="font-mono text-caption uppercase tracking-widest text-ink-faded hover:text-ink transition-colors hidden md:block">Home</a>
    </div>
  </nav>

  <main class="max-w-5xl mx-auto px-4 sm:px-6 pb-24">

    <!-- HERO SECTION -->
    <header class="pt-10 pb-8 border-b-2 border-ink">
      <div class="flex items-start justify-between gap-4 mb-4 flex-wrap">
        <span class="section-label">{project.category}</span>
        {project.award && <span class="font-mono text-caption text-ink border border-ink px-3 py-1 text-xs">{project.award}</span>}
      </div>
      <h1 class="font-display font-black text-ink leading-tight mb-4 text-balance" style="font-size: clamp(2rem, 5vw, 3.5rem);">{project.headline}</h1>
      <p class="font-serif italic text-body-print text-ink-light mb-6 max-w-3xl text-lg">{project.overview}</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-0 border-t-2 border-b-2 border-ink py-3">
        {[{label:'Date',value:project.date},{label:'Duration',value:project.duration},{label:'Team',value:project.team},{label:'Category',value:project.category}].map((m: any, i: number) => (
          <div class={`px-4 text-center ${i < 3 ? 'border-r border-ink' : ''}`}>
            <p class="font-mono text-caption text-ink-faded uppercase tracking-wider mb-0.5">{m.label}</p>
            <p class="font-serif font-bold text-ink text-sm">{m.value}</p>
          </div>
        ))}
      </div>
      <div class="flex flex-wrap gap-2 mt-4">
        {project.tags.map((tag: string) => <span class="font-mono text-caption border border-ink px-2 py-0.5 text-ink text-xs">{tag}</span>)}
      </div>
    </header>

    <!-- IMAGE CAROUSEL -->
    <section class="border-b-2 border-ink" data-carousel data-count={project.images.length}>
      <div class="relative overflow-hidden" style="height:480px;">
        <div class="carousel-track flex h-full" style="transition:transform 0.5s ease-in-out;">
          {project.images.map((img: string, i: number) => (
            <div class="carousel-slide flex-shrink-0 w-full h-full">
              <img src={`${base}${img.slice(1)}`} class="w-full h-full object-cover" alt={`${project.title} screenshot ${i + 1}`} />
            </div>
          ))}
        </div>
        <button class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 z-10 border-2 border-ink bg-paper w-12 h-12 flex items-center justify-center font-mono text-2xl leading-none hover:bg-ink hover:text-paper transition-all">&#8249;</button>
        <button class="carousel-next absolute right-3 top-1/2 -translate-y-1/2 z-10 border-2 border-ink bg-paper w-12 h-12 flex items-center justify-center font-mono text-2xl leading-none hover:bg-ink hover:text-paper transition-all">&#8250;</button>
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
          {project.images.map((_: any, i: number) => (
            <button class="carousel-dot w-2.5 h-2.5 bg-ink transition-opacity" style={i === 0 ? 'opacity:1' : 'opacity:0.3'}></button>
          ))}
        </div>
        <div class="absolute bottom-4 right-4 font-mono text-xs text-ink bg-paper border border-ink px-2 py-1">
          <span class="carousel-counter">01 / {String(project.images.length).padStart(2, '0')}</span>
        </div>
      </div>
    </section>

    <!-- PROBLEM / SOLUTION -->
    <section class="py-8 border-b-2 border-ink">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <div class="md:border-r border-ink pr-0 md:pr-8 pb-8 md:pb-0">
          <div class="rule-thick mb-4"></div>
          <p class="section-label font-bold mb-3">The Problem</p>
          <p class="font-serif text-body-print text-ink-light leading-relaxed">{project.problem}</p>
        </div>
        <div class="pl-0 md:pl-8 pt-8 md:pt-0 border-t md:border-t-0 border-ink">
          <div class="rule-thick mb-4"></div>
          <p class="section-label font-bold mb-3">The Solution</p>
          <p class="font-serif text-body-print text-ink-light leading-relaxed">{project.solution}</p>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="py-8 border-b-2 border-ink">
      <div class="flex items-center gap-3 mb-6">
        <span class="section-label font-bold">Key Features</span>
        <div class="flex-1 border-t border-ink"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {project.features.map((f: any, i: number) => (
          <div class="border-2 border-ink p-5 bg-column-bg">
            <p class="font-mono text-caption text-ink-faded mb-2">0{i+1}</p>
            <p class="font-display font-bold text-ink mb-2">{f.title}</p>
            <p class="font-serif text-body-print text-ink-light text-sm">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TECH STACK -->
    <section class="py-8 border-b-2 border-ink">
      <div class="flex items-center gap-3 mb-6">
        <span class="section-label font-bold">Tech Stack</span>
        <div class="flex-1 border-t border-ink"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {Object.entries(project.techStack).map(([cat, techs]: [string, any]) => (
          <div>
            <p class="font-mono text-caption uppercase tracking-widest text-ink-faded mb-3 border-b border-ink pb-1">{cat}</p>
            <div class="flex flex-wrap gap-2">
              {(techs as string[]).map((t: string) => <span class="font-mono text-caption border-2 border-ink px-3 py-1 text-ink text-xs">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FOOTER NAV -->
    <section class="pt-8 flex items-center justify-between flex-wrap gap-4">
      <a href={`${base}projects`} class="font-mono text-caption uppercase tracking-widest border-2 border-ink px-6 py-3 hover:bg-ink hover:text-paper transition-all">← All Projects</a>
      <a href={base} class="font-mono text-caption uppercase tracking-widest border-2 border-ink px-6 py-3 hover:bg-ink hover:text-paper transition-all">Back to Portfolio</a>
    </section>

  </main>
<script is:inline>
  document.querySelectorAll('[data-carousel]').forEach(function(carousel) {
    var track = carousel.querySelector('.carousel-track');
    var dots = carousel.querySelectorAll('.carousel-dot');
    var counter = carousel.querySelector('.carousel-counter');
    var total = parseInt(carousel.dataset.count || '3'), cur = 0;
    function go(n) {
      cur = ((n % total) + total) % total;
      track.style.transform = 'translateX(-' + (cur * 100) + '%)';
      dots.forEach(function(d, i) { d.style.opacity = i === cur ? '1' : '0.3'; });
      if (counter) counter.textContent = String(cur + 1).padStart(2, '0') + ' / 03';
    }
    carousel.querySelector('.carousel-prev').addEventListener('click', function() { go(cur - 1); });
    carousel.querySelector('.carousel-next').addEventListener('click', function() { go(cur + 1); });
    dots.forEach(function(d, i) { d.addEventListener('click', function() { go(i); }); });
  });
</script>
</body>
</html>
