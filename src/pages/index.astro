---
import '../styles/global.css';
const base = import.meta.env.BASE_URL;

const today = new Date();
const edition = today.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase();

// Award-winning projects showcase
const awardProjects = [
  {
    slug: '3ducate',
    headline: 'AR Anatomical Platform Wins First Place With Generative AI Contextual Explanations',
    deck: '3Ducate layers augmented reality over anatomical models, with an AI layer that explains any structure in natural language on demand.',
    tags: ['Python', 'AR', 'Computer Vision', 'Generative AI'],
    award: '1st Place — HawkHack 2025',
    awardType: 'gold',
    col: 'EDTECH & AR',
    body: 'Led a four-member team to build an AR educational platform capable of overlaying anatomical models on real-world surfaces and answering student questions with Generative AI explanations. Judges awarded first place for innovation and technical execution among all submissions.',
  },
  {
    slug: 'siteiq',
    headline: 'Autonomous AI Agent Delivers Invest/Avoid Verdicts on NYC Real Estate in Seconds',
    deck: 'SiteIQ fuses geospatial mapping, live transit data, and generative AI to produce structured investment reports — automating what once took analysts hours.',
    tags: ['Python', 'Geospatial APIs', 'Generative AI'],
    award: '3rd Place — Anti-Slopathon, Mar 2026',
    awardType: 'bronze',
    col: 'REAL ESTATE & AI',
    body: 'The platform ingests live NYC transit feeds, zoning data, and property records into a geospatial pipeline, feeding an autonomous reasoning agent that issues a binary Invest/Avoid verdict with a structured supporting report.',
  },
  {
    slug: 'pinpoint',
    headline: 'Decentralized Protocol Anchors Physical Reality Against Deepfakes via Solana Blockchain',
    deck: 'Pin Point immutably stamps location-verified media on-chain with on-device ML filtering — shipped end-to-end in 24 hours.',
    tags: ['On-device ML', 'Solana', 'Blockchain'],
    award: 'Best Use of Solana — QuackHacks, Feb 2026',
    awardType: 'silver',
    col: 'WEB3 & SECURITY',
    body: 'Deepfake proliferation demanded a trustless answer. Pin Point anchors ML-filtered, GPS-stamped media to a Solana reputation ledger, creating an unforgeable audit trail. Shipped in 24 hours.',
  },
];

// Featured blogs
const blogs = [
  {
    date: 'April 2026',
    title: 'Shipping AI Systems in Days, Not Months: A Practitioner\'s Playbook',
    excerpt: 'How disciplined sprint execution, cloud-native architecture, and clear architectural ownership compress deployment timelines by 10x.',
    tags: ['AI', 'Engineering', 'DevOps'],
  },
  {
    date: 'March 2026',
    title: 'Building Autonomous Agents with Local LLMs and Geospatial Pipelines',
    excerpt: 'Deep dive into designing reasoning agents that fuse external data sources (APIs, BigQuery, Solana) for autonomous decision-making in production.',
    tags: ['AI Agents', 'LLMs', 'Architecture'],
  },
];

// Other projects
const otherProjects = [
  {
    slug: 'piggilytics',
    headline: 'AI Financial Platform Generates Video Explainers of Your Spending Behavior',
    deck: 'Piggilytics AI automates statement parsing, builds live dashboards, and produces AI-narrated video breakdowns of personal finance patterns.',
    tags: ['Python', 'Flask', 'PyTorch', 'Gemini API'],
    col: 'FINTECH',
    body: 'Using NLP models and the Gemini API, the platform transforms raw bank statements into structured analytics and automatically generates spoken-word video reports — making financial data comprehensible and actionable for non-technical users.',
  },
  {
    slug: 'dealscout',
    headline: 'Full-Stack Price Comparison App Goes from Figma Wireframe to Azure Production in Two Weeks',
    deck: 'Deal Scout proves that disciplined Agile sprints and modern cloud tooling can compress deployment timelines by an order of magnitude.',
    tags: ['React', 'Python', 'Azure'],
    col: 'E-COMMERCE',
    body: 'Starting from a Figma wireframe, the full-stack application — including web-scraping pipelines, a React frontend, and Azure deployment infrastructure — was conceived, designed, built, and shipped in under fourteen days.',
  },
  {
    slug: 'covpred',
    headline: 'Year-Long Thesis Builds End-to-End Epidemiology & Genomics Analytics Platform',
    deck: 'CovPred integrates public health, DNA, and research datasets with AI-generated official reports and epidemic-spread dashboards.',
    tags: ['Python', 'CDC APIs', 'Gemini API', 'Bioinformatics'],
    col: 'RESEARCH',
    body: 'Drawing on CDC feeds, government datasets, and genomic databases, CovPred visualizes DNA mutation patterns alongside epidemic-spread trajectories. Automated report generation via Gemini API allows public health insights to be compiled without manual writing overhead.',
  },
];

// Comprehensive skills
const skills = {
  'Languages': ['Python', 'JavaScript', 'SQL', 'C', 'TypeScript'],
  'AI/ML': ['Vertex AI', 'OpenAI API', 'Gemini API', 'LLM Agents', 'RAG Systems', 'PyTorch', 'NLP', 'Embeddings', 'Computer Vision'],
  'Cloud & Infra': ['GCP (Cloud Run)', 'BigQuery', 'Cloud Functions', 'Pub/Sub', 'AWS Lambda', 'Azure', 'Docker', 'Kubernetes'],
  'Frontend': ['React', 'Next.js', 'Astro', 'Tailwind CSS', 'Flask', 'FastAPI'],
  'Data & ML Eng': ['ETL Pipelines', 'Data Science', 'Bioinformatics', 'Feature Engineering', 'Model Training', 'Analytics'],
  'DevOps & Tools': ['CI/CD (GitHub Actions)', 'Cloud Build', 'Monitoring', 'Git', 'Agile/Scrum', 'TDD', 'REST APIs'],
};

const experience = [
  {
    slug: 'wow-payments',
    role: 'Software Engineering Intern (Data & Backend)',
    company: 'WOW Payments',
    location: 'New York, USA',
    dates: 'May – Aug 2025',
    gist: 'Shipped production-grade CRM platform (Python, PHP, SQL) improving task execution by 41%. Reduced client onboarding from 3 days to 12 hours via backend optimization. Built orchestration pipelines lifting delivery accuracy to 98%.',
    bullets: [
      'Designed and deployed CRM platform; improved throughput by 41%.',
      'Reduced onboarding latency from 3 days to 12 hours.',
      'Built orchestration pipelines; lifted accuracy to 98%.',
    ],
  },
  {
    slug: 'virtusa',
    role: 'AI & ML Engineering Intern',
    company: 'Virtusa',
    location: 'Chennai, India',
    dates: 'Aug – Dec 2023',
    gist: 'Re-architected ETL pipelines scaling ingestion from 35% to 96%. Built NLP systems for ESG sentiment analysis across 300+ companies in distributed GCP environment.',
    bullets: [
      'Scaled ETL throughput from 35% to 96%.',
      'Built NLP systems for 300+ company ESG analysis.',
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Shreeram Sankar — AI Builder, Full-Stack Engineer, Rapid Prototyper. Portfolio." />
  <title>The Shreeram Chronicle — AI Builder & Engineer</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Playfair+Display+SC:wght@400;700;900&family=IBM+Plex+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Playfair+Display+SC:wght@400;700;900&family=IBM+Plex+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" />
</head>

<body class="bg-paper">

  <!-- ════════════════════════════════════════════
       STICKY NAV / TICKER
  ════════════════════════════════════════════ -->
  <nav class="sticky top-0 z-50 bg-paper border-b-2 border-ink no-print" aria-label="Site navigation">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-9">
      <div class="flex items-center gap-6 overflow-x-auto">
        {['Lead Story', 'Dispatches', 'Awards', 'Projects', 'Skills', 'Contact'].map(sec => (
          <a
            href={`#${sec.toLowerCase().replace(/ /g, '-')}`}
            class="font-mono text-caption uppercase tracking-widest text-ink-faded hover:text-accent-sepia whitespace-nowrap transition-colors duration-150"
          >
            {sec}
          </a>
        ))}
      </div>
      <span class="font-mono text-caption text-ink-faded hidden md:block" style="font-size: 0.65rem;">© {today.getFullYear()}</span>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-24">

    <!-- ════════════════════════════════════════════
         MASTHEAD
    ════════════════════════════════════════════ -->
    <header class="pt-8 pb-0 animate-on-scroll" id="lead-story">
      <div class="rule-thick mb-1"></div>
      <div class="flex items-center justify-between mb-1">
        <span class="font-mono text-caption uppercase tracking-widest text-ink-faded">Est. 2020 · New York, NY</span>
        <span class="font-mono text-caption uppercase tracking-widest text-ink-faded hidden sm:block">Vol. VII, No. 4</span>
        <span class="font-mono text-caption uppercase tracking-widest text-ink-faded text-right">April 2026</span>
      </div>
      <div class="rule-thin mb-2"></div>

      <!-- Masthead with decorative elements -->
      <div class="text-center py-4 md:py-6 border-b-2 border-ink relative overflow-hidden halftone-overlay">
        <div class="absolute inset-0 opacity-5 bg-gradient-to-br from-accent-sepia via-transparent to-accent-rust pointer-events-none"></div>
        <p class="font-mono text-caption uppercase tracking-[0.4em] text-ink-faded mb-2 relative z-10">The</p>
        <h1 class="font-display font-black uppercase leading-none tracking-tight text-ink relative z-10"
            style="font-size: clamp(2.8rem, 9vw, 7.5rem); text-shadow: 2px 2px 0 rgba(0,0,0,0.06);">
          Shreeram Chronicle
        </h1>
        <p class="font-mono text-caption uppercase tracking-[0.35em] text-ink-faded mt-2 relative z-10">
          AI&nbsp;Builder&nbsp;·&nbsp;Full‑Stack&nbsp;Engineer&nbsp;·&nbsp;Rapid&nbsp;Prototyper
        </p>
      </div>

      <div class="flex items-center gap-4 py-2 border-b border-ink flex-wrap">
        <span class="ink-stamp animate-stamp">Breaking</span>
        <p class="font-serif italic text-deck text-ink-light text-balance">
          "Full-stack engineer ships 20+ production systems in days, not months — 5× hackathon winner, zero setup cost, maximum impact."
        </p>
      </div>
    </header>

    <!-- ════════════════════════════════════════════
         LEAD STORY — HERO
    ════════════════════════════════════════════ -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-0 border-b-2 border-ink mt-0 animate-on-scroll" aria-label="About Shreeram">
      <div class="md:col-span-8 md:border-r border-ink py-6 pr-0 md:pr-6">
        <div class="dateline mb-2">New York, NY — Special Report</div>
        <h2 class="font-display font-black text-ink leading-tight mb-3 text-balance"
            style="font-size: clamp(1.6rem, 4vw, 3rem);">
          Full-Stack AI Engineer Arrives in New York to Ship Production Systems at Unprecedented Velocity
        </h2>
        <div class="rule-thin mb-3"></div>
        <div class="byline mb-4">By SHREERAM SANKAR · NYC, 2026</div>

        <p class="font-serif text-body-print text-ink-light drop-cap mb-3">
          Shreeram Sankar is a full-stack software engineer and AI builder currently pursuing his M.S. in Computer Science at NYU Tandon School of Engineering, backed by a B.E. from Anna University and 2+ years of production experience across New York and Chennai.
        </p>
        <p class="font-serif text-body-print text-ink-light mb-3">
          His toolkit spans Python, GCP, React, Vertex AI, OpenAI and Gemini APIs, LLM agents, RAG systems, CI/CD pipelines, and cloud-native architectures. He has shipped autonomous AI agents, scalable REST APIs, ETL pipelines, and LLM-integrated platforms — consistently delivering in days, not months.
        </p>
        <p class="font-serif text-body-print text-ink-light mb-4">
          A 5× hackathon winner, Sankar is equally comfortable in ambiguous early-stage problems and production-grade systems requiring robustness, monitoring, and reliability. His recent roles span financial-tech CRM systems (WOW Payments) and distributed ML/ETL infrastructure for ESG analytics (Virtusa).
        </p>

        <!-- Stats row with vintage styling -->
        <div class="grid grid-cols-3 gap-0 border-t-2 border-b-2 border-ink py-3 mt-4">
          {[
            { stat: '20+', label: 'Shipped Projects' },
            { stat: '2+', label: 'Years Production' },
            { stat: '5×', label: 'Hackathon Wins' },
          ].map((item, i) => (
            <div class={`text-center ${i < 2 ? 'border-r border-ink' : ''} px-2`}>
              <div class="font-display font-black text-ink" style="font-size:2.2rem;">{item.stat}</div>
              <div class="font-mono text-caption uppercase tracking-wider text-ink-faded">{item.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Col 2: Sidebar with education + article CTA -->
      <div class="md:col-span-4 py-6 pl-0 md:pl-6">
        <!-- Recent Articles CTA Button -->
        <div class="border-2 border-ink p-4 mb-4 bg-paper text-center">
          <p class="section-label mb-3 font-bold">Keep Reading</p>
          <a href={`${base}blogs`} class="font-display font-bold text-ink border-b-2 border-ink hover:bg-column-bg px-3 py-2 inline-block transition-all">
            Check out my articles
          </a>
          <p class="text-xs text-ink-faded mt-3 italic">Shipping AI Systems in Days, Not Months</p>
        </div>

        <!-- Article Image -->
        <div class="border-2 border-ink mb-4 overflow-hidden">
          <img src={`${base}hero-image.png`} alt="Articles" class="w-full h-48 object-cover" />
        </div>

        <!-- Education box -->
        <div class="border-2 border-ink p-4">
          <p class="section-label mb-2 font-bold">Education</p>
          <div class="mb-3 pb-3 border-b border-ink">
            <p class="font-serif font-bold text-sm text-ink leading-tight">NYU Tandon School of Engineering</p>
            <p class="font-mono text-caption text-ink-faded">M.S. Computer Science</p>
            <p class="font-mono text-caption text-ink-faded">Aug 2024 – May 2026</p>
          </div>
          <div>
            <p class="font-serif font-bold text-sm text-ink leading-tight">Anna University</p>
            <p class="font-mono text-caption text-ink-faded">B.E. Computer Science</p>
            <p class="font-mono text-caption text-ink-faded">Nov 2020 – May 2024</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         DISPATCHES — WORK EXPERIENCE
    ════════════════════════════════════════════ -->
    <section id="dispatches" class="py-8 border-b-2 border-ink animate-on-scroll" aria-label="Work experience">
      <div class="flex items-center gap-3 mb-1">
        <span class="section-label">Dispatches from the Field</span>
        <div class="flex-1 border-t border-ink"></div>
        <span class="section-label">Work Experience</span>
      </div>
      <div class="rule-double mb-6"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        {experience.map((job, i) => (
          <div class={`py-4 pr-0 ${i === 0 ? 'md:pr-8 md:border-r border-ink' : 'md:pl-8'} animate-on-scroll`} style={`animation-delay: ${i * 100}ms`}>
            <span class="ink-stamp mb-3 block w-fit bg-column-bg">{job.dates}</span>
            <h3 class="font-display font-bold text-ink leading-tight mb-0.5" style="font-size:1.3rem;">{job.role}</h3>
            <p class="font-mono text-caption uppercase tracking-wider text-ink mb-2">{job.company} · {job.location}</p>
            <p class="font-serif text-body-print text-ink-light mb-3 italic">{job.gist}</p>
            <a href={`${base}work/${job.slug}`} class="read-more-btn">View Full Details →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         AWARDS SECTION
    ════════════════════════════════════════════ -->
    <section id="awards" class="py-8 border-b-2 border-ink animate-on-scroll" aria-label="Award winning projects">
      <div class="flex items-center gap-3 mb-1">
        <span class="section-label font-bold">Award Winners</span>
        <div class="flex-1 border-t-2 border-ink"></div>
        <span class="section-label">Hackathon Champions</span>
      </div>
      <div class="rule-double mb-6"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        {awardProjects.map((p, i) => (
          <article class="article-card border-2 border-ink animate-on-scroll" style={`animation-delay: ${i * 80}ms`}>
            <div class="flex items-center justify-between mb-2">
              <span class="font-serif font-bold text-ink text-sm">{p.award}</span>
            </div>
            <span class="section-label text-ink-faded block mb-2">{p.col}</span>
            <h3 class="card-headline font-display font-bold text-ink leading-tight mb-2 text-balance" style="font-size:1.05rem;">
              {p.headline}
            </h3>
            <p class="font-serif italic text-body-print text-ink-faded mb-3 border-b border-ink pb-3">{p.deck}</p>
            <div class="flex flex-wrap gap-1 mt-auto">
              {p.tags.map(tag => <span class="tag-badge">{tag}</span>)}
            </div>
            <a href={`${base}award/${p.slug}`} class="read-more-btn">Full Case Study →</a>
          </article>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         PROJECTS — OTHER DISPATCHES
    ════════════════════════════════════════════ -->
    <section id="projects" class="py-8 border-b-2 border-ink animate-on-scroll" aria-label="Projects">
      <div class="flex items-center gap-3 mb-1">
        <span class="section-label">Featured Projects</span>
        <div class="flex-1 border-t border-ink"></div>
        <span class="section-label">Latest Shipments</span>
      </div>
      <div class="rule-double mb-6"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
        {otherProjects.map((p, i) => (
          <article class="border-2 border-ink bg-paper flex flex-col animate-on-scroll hover:border-ink-light transition-all" style={`animation-delay: ${i * 80}ms`}>
            <div class="p-4 flex flex-col flex-1">
              <span class="section-label text-ink block mb-2">{p.col}</span>
              <h3 class="font-display font-bold text-ink leading-tight mb-2 text-balance" style="font-size:1rem;">
                {p.headline}
              </h3>
              <p class="font-serif italic text-body-print text-ink-faded mb-3 text-sm flex-1">{p.deck}</p>
              <div class="flex flex-wrap gap-1 mb-3">
                {p.tags.map((tag: string) => <span class="tag-badge">{tag}</span>)}
              </div>
              <a href={`${base}project/${p.slug}`} class="font-mono text-caption uppercase tracking-wide text-ink border-b-2 border-ink hover:text-ink-light transition-colors inline-block">View Project →</a>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center border-t border-ink pt-6">
        <a href={`${base}projects`} class="font-mono text-caption uppercase tracking-widest border-2 border-ink px-6 py-3 hover:bg-ink hover:text-paper transition-all duration-200 inline-block">
          ▶ View All Projects
        </a>
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         CLASSIFIEDS — SKILLS
    ════════════════════════════════════════════ -->
    <section id="skills" class="py-8 border-b-2 border-ink animate-on-scroll" aria-label="Technical skills">
      <div class="flex items-center gap-3 mb-1">
        <span class="section-label">Technical Arsenal</span>
        <div class="flex-1 border-t border-ink"></div>
        <span class="section-label">Comprehensive Stack</span>
      </div>
      <div class="rule-double mb-6"></div>

      <!-- 6-column grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-0 border border-ink">
        {Object.entries(skills).map(([cat, items], i) => (
          <div class={`p-3 border-r border-b border-ink last:border-r-0 ${i % 6 < 5 ? 'md:border-r' : 'md:border-r-0'} animate-on-scroll`} style={`animation-delay: ${i * 50}ms`}>
            <div class="rule-thick mb-2 border-ink"></div>
            <p class="section-label text-ink font-bold text-xs mb-2">{cat}</p>
            <ul class="space-y-0.5">
              {items.map(item => (
                <li><span class="tag-badge text-xs">{item}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         CONTACT
    ════════════════════════════════════════════ -->
    <section id="contact" class="py-8 animate-on-scroll" aria-label="Contact">
      <div class="flex items-center gap-3 mb-1">
        <span class="section-label">Get in Touch</span>
        <div class="flex-1 border-t border-ink"></div>
        <span class="section-label">Direct Line</span>
      </div>
      <div class="rule-double mb-6"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h2 class="font-display font-black text-ink leading-tight mb-3 text-balance" style="font-size:clamp(1.4rem,3vw,2.4rem);">
            Got a Story Worth Building?
          </h2>
          <div class="rule-thin mb-4 border-ink"></div>
          <p class="font-serif text-body-print text-ink-light drop-cap mb-4">
            The Chronicle is always looking for stories worth shipping. Whether you need an autonomous agent in a week, a production ETL redesigned overnight, or a full-stack application completed before your competitor, this desk picks up every assignment.
          </p>
          <p class="font-serif text-body-print text-ink-light mb-6">
            Open to full-time roles, consulting engagements, and collaborations that push the boundaries of what's possible with modern AI, cloud infrastructure, and rapid iteration.
          </p>

          <div class="border-2 border-ink p-4 bg-paper-cream">
            <p class="section-label text-ink font-bold mb-3">Primary Wire</p>
            <a href="mailto:sshreeramsankar@gmail.com" class="font-serif font-bold text-ink hover:text-ink-light transition-colors text-lg underline underline-offset-2 block mb-2">
              sshreeramsankar@gmail.com
            </a>
            <p class="font-serif text-body-print text-ink-light">
              For opportunities, inquiries, or to discuss your next ambitious project.
            </p>
          </div>
        </div>

        <div class="flex items-center">
          <div class="w-full">
            <div class="border-2 border-ink p-8 bg-column-bg text-center">
              <p class="font-mono text-caption uppercase tracking-widest text-ink-faded mb-2">Quick Links</p>
              <div class="rule-thin mb-6 border-ink"></div>
              <div class="space-y-3">
                <a href="https://linkedin.com/in/shreeramsankar" target="_blank" rel="noopener noreferrer" class="font-serif font-bold text-ink hover:text-ink-light transition-colors text-base block underline underline-offset-2">
                  LinkedIn Profile
                </a>
                <a href="mailto:sshreeramsankar@gmail.com" class="font-serif font-bold text-ink hover:text-ink-light transition-colors text-base block underline underline-offset-2">
                  Send Email
                </a>
                <a href="#projects" class="font-serif font-bold text-ink hover:text-ink-light transition-colors text-base block underline underline-offset-2">
                  Explore Projects
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- ════════════════════════════════════════════
       FOOTER
  ════════════════════════════════════════════ -->
  <footer class="border-t-4 border-ink bg-paper py-6 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-display font-black uppercase text-ink" style="font-size:1.4rem; letter-spacing:-0.01em;">The Shreeram Chronicle</p>
          <p class="font-mono text-caption uppercase tracking-widest text-ink-faded">Edition {today.getFullYear()} · All Dispatches Archived</p>
        </div>

        <div class="flex items-center gap-4">
          <a
            href="mailto:sshreeramsankar@gmail.com"
            class="font-mono text-caption uppercase tracking-widest text-ink opacity-60 hover:opacity-100 transition-all duration-150"
          >
            Email
          </a>
          <span class="text-ink opacity-30">·</span>
          <a
            href="https://linkedin.com/in/shreeramsankar"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-caption uppercase tracking-widest text-ink opacity-60 hover:opacity-100 transition-all duration-150"
          >
