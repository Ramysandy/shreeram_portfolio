              class="font-mono text-caption uppercase tracking-widest border border-ink text-ink px-3 py-1 hover:bg-ink hover:text-paper transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-ink"
              aria-label="Print this portfolio"
            >
              ⎙ Print
            </button>
          </div>
