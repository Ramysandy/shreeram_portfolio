---
import '../../styles/global.css';

const today = new Date();

const blogs = [
  {
    slug: 'shipping-ai-systems',
    title: 'Shipping AI Systems in Days, Not Months',
    date: 'March 15, 2025',
    readTime: '8 min read',
    excerpt: 'How constraints and pragmatism let us ship production AI features at speed. Deep dive into LLM APIs, caching strategies, and knowing when to build vs. integrate.',
    category: 'ENGINEERING',
  },
  {
    slug: 'autonomous-agents',
    title: 'The Case for Autonomous Agents Over Chatbots',
    date: 'February 28, 2025',
    readTime: '10 min read',
    excerpt: 'Why the future of AI isn\'t conversational. Autonomous agents can reason, use tools, backtrack, and solve complex problems without human-in-the-loop. Here\'s why they matter.',
    category: 'AI',
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>All Articles — The Shreeram Chronicle</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Playfair+Display+SC:wght@400;700;900&family=IBM+Plex+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" />
</head>

<body class="bg-paper">

  <nav class="sticky top-0 z-50 bg-paper border-b-2 border-ink no-print">
    <div class="max-w-4xl mx-auto px-4 flex items-center justify-between h-9">
      <a href="/" class="font-mono text-caption uppercase tracking-widest text-ink hover:text-ink-light transition-colors">
        ← Back to Portfolio
      </a>
      <span class="font-mono text-caption text-ink-faded hidden md:block" style="font-size: 0.65rem;">© {today.getFullYear()}</span>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <!-- Header -->
    <header class="mb-12 pb-6 border-b-4 border-ink">
      <h1 class="font-display font-black text-ink leading-tight mb-2" style="font-size: clamp(2.5rem, 6vw, 4rem);">
        Articles & Dispatches
      </h1>
      <p class="font-serif italic text-body-print text-ink-faded">
        Essays on AI, systems thinking, and building in the open.
      </p>
    </header>

    <!-- Articles Grid -->
    <div class="space-y-6 mb-12">
      {blogs.map(blog => (
        <article class="border-2 border-ink p-6 bg-column-bg hover:bg-paper-cream transition-colors">
          <div class="flex items-center justify-between mb-3">
            <span class="section-label">{blog.category}</span>
            <span class="dateline">{blog.readTime}</span>
          </div>
          
          <a href={`/blog/${blog.slug}`} class="group">
            <h2 class="font-display font-bold text-ink mb-3 leading-tight group-hover:text-ink-light transition-colors" style="font-size: 1.75rem;">
              {blog.title}
            </h2>
          </a>
          
          <p class="font-serif text-body-print text-ink-light mb-4 leading-relaxed">
            {blog.excerpt}
          </p>
          
          <div class="flex items-center justify-between">
            <span class="font-mono text-caption text-ink-faded uppercase tracking-wider">
              {blog.date}
            </span>
            <a href={`/blog/${blog.slug}`} class="font-mono text-caption uppercase tracking-widest border border-ink px-3 py-1 text-ink hover:bg-ink hover:text-paper transition-all">
              Read →
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer Link -->
    <div class="text-center">
      <a href="/" class="font-mono text-caption uppercase tracking-widest border border-ink px-4 py-2 text-ink hover:bg-ink hover:text-paper transition-all inline-block">
        ← Back to Portfolio
      </a>
    </div>
  </main>

  <footer class="border-t-4 border-ink bg-paper py-6 px-4 mt-16">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-display font-black uppercase text-ink" style="font-size:1.4rem; letter-spacing:-0.01em;">The Shreeram Chronicle</p>
      <p class="font-mono text-caption uppercase tracking-widest text-ink-faded">All Rights Reserved · {today.getFullYear()}</p>
    </div>
  </footer>

</body>
</html>
